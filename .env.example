# --- Runway CLI Configuration ---

# 1. Database Connection (Option A - Unified URL)
# Use this for a single connection string.
# DATABASE_URL=postgres://user:password@localhost:5432/dbname

# 2. Database Connection (Option B - Individual Components)
# Used if DATABASE_URL is not provided.
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=runway_db
DB_SSL=false

# 3. Path & Logic Configuration
# Directory where your migration files are stored (default: ./migrations)
# RUNWAY_MIGRATIONS_DIR=./migrations

# Database schema used for the migrations table (default: public)
# RUNWAY_SCHEMA=public

# 4. Environment Management
# USE cases: development, staging, production
# Notes for RUNWAY_ENV:
# - Use 'development' for local work (default if not set).
# - Use 'production' to enforce stricter migration checks.
# - You can also use different .env files like .env.production for CI/CD.
RUNWAY_ENV=development
