# Runway Environment Variables Example
# Copy this file to .env and fill in your database credentials.

# Option 1: Using a connection string
DATABASE_URL=postgresql://user:password@localhost:5432/mydb

# Option 2: Using individual variables (takes precedence if defined)
DB_HOST=localhost
DB_PORT=5432
DB_USER=myuser
DB_PASSWORD=mypassword
DB_NAME=mydb

# Optional: Enable SSL for the connection (true/false)
DB_SSL=false
