{
  "name": "@vlynk-studios/runway",
  "version": "0.4.1",
  "description": "Runway — SQL migration CLI for Node.js, PostgreSQL, MySQL and MariaDB",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/Vlynk-Studios/Runway.git"
  },
  "homepage": "https://github.com/Vlynk-Studios/Runway#readme",
  "bugs": {
    "url": "https://github.com/Vlynk-Studios/Runway/issues"
  },
  "bin": {
    "runway": "./bin/runway.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:integration": "node --experimental-vm-modules node_modules/jest/bin/jest.js test/integration-postgres.test.js --testPathIgnorePatterns 'node_modules'",
    "test:integration:mysql": "node --experimental-vm-modules node_modules/jest/bin/jest.js test/integration-mysql.test.js --testPathIgnorePatterns 'node_modules'",
    "test:integration:mariadb": "node --experimental-vm-modules node_modules/jest/bin/jest.js test/integration-mariadb.test.js --testPathIgnorePatterns 'node_modules'",
    "test:integration:all": "node --experimental-vm-modules node_modules/jest/bin/jest.js test/integration-postgres.test.js test/integration-mysql.test.js test/integration-mariadb.test.js --testPathIgnorePatterns 'node_modules'",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "prepublishOnly": "npm run lint && npm test"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "testPathIgnorePatterns": [
      "/node_modules/",
      "integration-.*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/templates/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "keywords": [
    "migrations",
    "sql",
    "postgres",
    "postgresql",
    "mysql",
    "mariadb",
    "cli",
    "database",
    "devtools"
  ],
  "author": "Vlynk Studios And Keiver-Dev",
  "license": "MIT",
  "files": [
    "bin/",
    "src/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    ".env.example"
  ],
  "dependencies": {
    "chalk": "5.6.2",
    "commander": "14.0.3",
    "dotenv": "17.3.1",
    "inquirer": "13.3.2",
    "mysql2": "3.20.0",
    "ora": "9.3.0",
    "pg": "8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "9.10.0",
    "@testcontainers/mariadb": "^11.13.0",
    "@testcontainers/mysql": "11.13.0",
    "@testcontainers/postgresql": "11.13.0",
    "eslint": "9.39.4",
    "globals": "17.4.0",
    "jest": "30.3.0",
    "prettier": "3.8.1",
    "testcontainers": "11.13.0"
  }
}
